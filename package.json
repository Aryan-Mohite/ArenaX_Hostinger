{
  "name": "arenax",
  "version": "1.0.0",
  "description": "ArenaX eSports Platform — Hostinger Node.js deployment",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --env-file=.env server.js",
    "build:frontend": "cd frontend && npm install --include=dev && npm run build",
    "postinstall": "npm run build:frontend"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.2.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.22.4",
    "nodemailer": "^8.0.7",
    "sanitize-html": "^2.13.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
