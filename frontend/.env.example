# ─── Frontend environment variables ───────────────────────────────────────────
# Copy this file to .env.production for production builds, or .env.local for
# local overrides. Vite only exposes variables prefixed with VITE_.

# FIX H4: Set this to your deployed backend URL for production builds.
# If frontend and backend are served from the same origin (via Nginx reverse proxy),
# you can leave this unset — the default '/api' relative path will work.
# Example: VITE_API_URL=https://api.arenaX.gg/api
VITE_API_URL=

# Optional: Override socket.io server URL (defaults to same origin as API)
# VITE_SOCKET_URL=https://api.arenaX.gg
