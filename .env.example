# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── Database (MySQL) ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=arenax

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# ─── Email (Nodemailer — for verification & password reset) ───────────────────
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=no-reply@yourdomain.com
EMAIL_PASS=your_smtp_password
EMAIL_FROM="ArenaX <no-reply@yourdomain.com>"

# ─── App URL (used in email links) ───────────────────────────────────────────
APP_URL=https://yourdomain.com
